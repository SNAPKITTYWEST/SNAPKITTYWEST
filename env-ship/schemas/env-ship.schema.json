{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sovereign-transformer.io/schemas/envelope-v1.json",
  "title": "Sovereign Script Envelope",
  "type": "object",
  "required": [
    "envelope_version",
    "envelope_id",
    "author",
    "infrastructure",
    "trust_protocol",
    "audit_spec",
    "fiscal_governance",
    "timestamp",
    "hash",
    "payload_b64"
  ],
  "properties": {
    "envelope_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "envelope_id": { "type": "string", "pattern": "^env-[a-f0-9]{16}-\\d+$" },
    "author": { "type": "string", "const": "AhmadAliParr" },
    "infrastructure": { "type": "string", "const": "Local_First_Sovereign_OS" },
    "trust_protocol": { "type": "string", "const": "Bifrost_WORM_Chain" },
    "audit_spec": { "type": "string", "format": "uuid" },
    "fiscal_governance": { "type": "string", "const": "Codestorm_Hub_Federated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "proof_ref": {
      "type": ["string", "null"],
      "pattern": "^(proof|lean|isabelle|worm)://.+$"
    },
    "payload_b64": { "type": "string", "minLength": 1, "description": "Base64-encoded script payload for exact byte preservation" },
    "signature": {
      "type": ["string", "null"],
      "description": "Base64-encoded Ed25519 signature of canonical envelope (excluding signature field)"
    }
  },
  "additionalProperties": false
}
